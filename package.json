{
  "name": "@organvm/stakeholder-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:offline": "tsx scripts/run-evals.ts",
    "maintenance:run": "tsx scripts/run-maintenance.ts",
    "validate-manifest": "tsx scripts/validate-manifest.ts",
    "generate": "python3 scripts/generate-manifest.py",
    "prebuild": "npm run generate -- --allow-stale-manifest && npm run validate-manifest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "ci:quality-gate": "tsx scripts/ci-quality-gate.ts",
    "escalation:seed": "tsx -e \"import('@/lib/alert-audit').then(m => m.seedEscalationPolicies()).then(() => console.log('Policies seeded.'))\"",
    "ingest:corpus": "tsx scripts/ingest-corpus.ts"
  },
  "dependencies": {
    "drizzle-orm": "0.45.1",
    "next": "^15.3.0",
    "next-auth": "5.0.0-beta.30",
    "pg": "8.20.0",
    "pgvector": "0.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "8.18.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "17.3.1",
    "drizzle-kit": "0.31.9",
    "eslint": "^9.38.0",
    "eslint-config-next": "^15.5.12",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "tsx": "4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}

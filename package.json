{
  "name": "@organvm/stakeholder-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:contracts": "npm run lint && npm run validate-manifest && npm run build && npm run ci:quality-gate",
    "eval:offline": "tsx scripts/run-evals.ts",
    "maintenance:run": "tsx scripts/run-maintenance.ts",
    "validate-manifest": "tsx scripts/validate-manifest.ts",
    "generate": "tsx src/lib/ingestion/ingest-worker.ts",
    "generate:incremental": "tsx src/lib/ingestion/ingest-worker.ts --incremental",
    "prebuild": "npm run generate -- --allow-stale-manifest --skip-vector && npm run validate-manifest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "ci:quality-gate": "tsx scripts/ci-quality-gate.ts",
    "escalation:seed": "tsx -e \"import('@/lib/alert-audit').then(m => m.seedEscalationPolicies()).then(() => console.log('Policies seeded.'))\"",
    "planning:seed": "tsx scripts/seed-planning.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@langchain/core": "1.1.31",
    "@langchain/textsplitters": "1.0.1",
    "drizzle-orm": "0.45.1",
    "langchain": "1.2.35",
    "next": "16.1.7",
    "next-auth": "5.0.0-beta.30",
    "pg": "8.20.0",
    "pgvector": "0.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "yaml": "2.8.2"
  },
  "overrides": {
    "flatted": "github:WebReflection/flatted#v3.4.2",
    "esbuild": "^0.25.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "8.18.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "17.3.1",
    "drizzle-kit": "0.31.9",
    "eslint": "^9.38.0",
    "eslint-config-next": "16.1.7",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "tsx": "4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}

# Preferred provider: Groq (open-source model hosting)
# Canonical enterprise reference (1Password):
# op://GitHub-Tokens/pwafmqe3dp35aiybsbdwjbl6dq/credential
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile

# Optional anonymous OSS fallback
OSS_LLM_API_URL=https://text.pollinations.ai/openai
OSS_LLM_MODEL=openai-fast
# OSS_LLM_API_KEY=

# Admin control-plane auth
ADMIN_API_TOKEN=
ADMIN_LOGIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Cron trigger auth
CRON_SECRET=
CRON_CONNECTOR_IDS=docs,workspace

# Outbound alert sinks + retry
ALERT_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
ALERT_SLACK_MENTION_CRITICAL=
ALERT_SLACK_MENTION_WARNING=
RESEND_API_KEY=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
ALERT_SINKS_DISABLED=0
ALERT_DISPATCH_WARNINGS=0
ALERT_DISPATCH_INFO=0
ALERT_SINK_MAX_RETRIES=2
ALERT_SINK_RETRY_BASE_MS=250
# JSON string, example:
# ALERT_ROUTING_JSON={"critical_channels":["webhook","slack","email"],"warning_channels":["webhook"]}

# ─── Database (Drizzle/Postgres) ──────────────────────────────────────────────
# Used for: distributed run locks, maintenance ledger, job queue, alert audit,
#           connector cursors, escalation policies
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stakeholder_portal

# ─── NextAuth SSO (Step 2) ────────────────────────────────────────────────────
AUTH_SECRET=             # npx auth secret
AUTH_GITHUB_ID=          # GitHub OAuth App: Settings > Developer settings > OAuth Apps
AUTH_GITHUB_SECRET=

# ─── Slack connector (Step 5) ─────────────────────────────────────────────────
SLACK_BOT_TOKEN=         # xoxb-... Bot User OAuth Token
SLACK_CHANNEL_IDS=       # Comma-separated channel IDs to sync, e.g. C01234567,C07654321

# ─── CI quality gate thresholds (Step 7 — override defaults) ─────────────────
ALERT_MIN_CITATION_COVERAGE=0.75
ALERT_MAX_HALLUCINATION_RATE=0.10
ALERT_MAX_EVAL_P95_MS=6000
ALERT_MAX_AUDIT_DENIED_RATIO=0.20
ALERT_MAX_INGEST_QUARANTINE_RATE=0.15
ALERT_MAX_INGEST_DEAD_LETTERS=20
